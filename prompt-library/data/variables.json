{
  "variableGroups": {
    "property": {
      "label": "物件資訊", "icon": "🏠",
      "fields": {
        "property_area": { "label": "區域", "type": "text", "placeholder": "例：信義區" },
        "property_community": { "label": "社區名稱", "type": "text", "placeholder": "例：翠亨村" },
        "property_size": { "label": "坪數", "type": "text", "placeholder": "例：30 坪", "suffix": "" },
        "property_rooms": { "label": "格局", "type": "text", "placeholder": "例：3 房" },
        "property_age": { "label": "屋齡", "type": "text", "placeholder": "例：10 年", "suffix": "" },
        "property_type": { "label": "物件類型", "type": "text", "placeholder": "例：住宅、套房、店面" },
        "property_features": { "label": "特色亮點", "type": "textarea", "placeholder": "例：採光好、近捷運" }
      }
    },
    "finance": {
      "label": "金融資訊", "icon": "💰",
      "fields": {
        "asking_price": { "label": "開價/售價", "type": "text", "placeholder": "例：1,500 萬" },
        "budget": { "label": "預算", "type": "text", "placeholder": "例：1,200-1,500 萬" },
        "monthly_rent": { "label": "月租", "type": "text", "placeholder": "例：18,000" },
        "management_fee": { "label": "管理費", "type": "text", "placeholder": "例：每月 2,500" },
        "down_payment": { "label": "頭期款/斡旋金", "type": "text", "placeholder": "例：200 萬" },
        "listing_price": { "label": "掛牌價", "type": "text", "placeholder": "例：1,680 萬" },
        "negotiation_price": { "label": "議價金額", "type": "text", "placeholder": "例：1,500 萬" }
      }
    },
    "client": {
      "label": "客戶資訊", "icon": "👤",
      "fields": {
        "client_name": { "label": "客戶姓名", "type": "text", "placeholder": "例：王大明" },
        "client_age": { "label": "年齡", "type": "text", "placeholder": "例：32 歲" },
        "client_type": { "label": "客戶類型", "type": "text", "placeholder": "例：首購族、換屋族" },
        "client_needs": { "label": "需求描述", "type": "textarea", "placeholder": "例：一家四口想換屋" }
      }
    },
    "time": {
      "label": "時間參數", "icon": "📅",
      "fields": {
        "silent_days": { "label": "沉默天數", "type": "text", "placeholder": "例：7", "suffix": "" },
        "analysis_period": { "label": "分析期間", "type": "text", "placeholder": "例：3 年" },
        "closing_date": { "label": "成交日期", "type": "text", "placeholder": "例：2024 年 3 月 15 日" }
      }
    },
    "agent": {
      "label": "業務員資訊", "icon": "🧑‍💼",
      "fields": {
        "agent_name": { "label": "業務員名稱", "type": "text", "placeholder": "例：阿峰" },
        "agent_area": { "label": "經營區域", "type": "text", "placeholder": "例：板橋、中和" },
        "agent_years": { "label": "年資", "type": "text", "placeholder": "例：5 年" },
        "brand_name": { "label": "品牌/公司名", "type": "text", "placeholder": "例：信義房屋" },
        "prev_company": { "label": "前公司", "type": "text", "placeholder": "例：永慶" },
        "deal_count": { "label": "成交件數", "type": "text", "placeholder": "例：120 件" },
        "team_size": { "label": "團隊人數", "type": "text", "placeholder": "例：12 位業務" },
        "platform": { "label": "平台", "type": "text", "placeholder": "例：FB、IG、LINE" }
      }
    },
    "content": {
      "label": "內容行銷", "icon": "✍️",
      "fields": {
        "content_topic": { "label": "主題/關鍵字", "type": "textarea", "placeholder": "例：房市政策新知、房貸利率小知識" },
        "hook_sentence": { "label": "開頭金句", "type": "textarea", "placeholder": "吸引點擊的第一句話" },
        "pain_point": { "label": "痛點描述", "type": "textarea", "placeholder": "目標受眾的痛點" },
        "lifestyle_scene": { "label": "生活場景", "type": "textarea", "placeholder": "描述理想生活畫面" },
        "seo_keyword_1": { "label": "SEO 關鍵字 1", "type": "text", "placeholder": "例：房仲推薦" },
        "seo_keyword_2": { "label": "SEO 關鍵字 2", "type": "text", "placeholder": "例：成交實績" }
      }
    },
    "holiday": {
      "label": "節慶行銷", "icon": "🎉",
      "fields": {
        "holiday_name": { "label": "節慶名稱", "type": "text", "placeholder": "例：農曆新年" },
        "holiday_theme_1": { "label": "主題 1", "type": "text", "placeholder": "例：新年新家" },
        "holiday_theme_2": { "label": "主題 2", "type": "text", "placeholder": "例：開運好宅" },
        "holiday_metaphor": { "label": "節慶比喻", "type": "text", "placeholder": "例：採光好 = 迎接新年第一道陽光" },
        "holiday_cta": { "label": "行動呼籲", "type": "text", "placeholder": "例：新年新家，立即預約" }
      }
    }
  },
